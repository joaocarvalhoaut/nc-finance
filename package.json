{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "diagnose:whatsapp-zapi": "node scripts/diagnose-whatsapp-zapi.js",
    "e2e:whatsapp": "node scripts/e2e-whatsapp-zapi.js",
    "e2e:whatsapp:report": "node scripts/e2e-whatsapp-zapi.js --report",
    "e2e:whatsapp:live": "LIVE_MODE=true node scripts/e2e-whatsapp-zapi.js --report",
    "test:parser": "npx tsx src/services/localDocumentExtraction/__tests__/normalizeText.test.ts && npx tsx src/services/localDocumentExtraction/__tests__/tableParser.test.ts && npx tsx src/services/localDocumentExtraction/__tests__/regexExtractors.test.ts && npx tsx src/services/localDocumentExtraction/__tests__/heuristics.test.ts && npx tsx src/services/localDocumentExtraction/__tests__/validation.test.ts",
    "test:hardening": "node scripts/hardening.js --report"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.106.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tesseract.js": "^7.0.0",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
