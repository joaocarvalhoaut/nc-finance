# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# Nunca use STRIPE_SECRET_KEY aqui — apenas a publishable key é segura no frontend.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# E-mail da Service Account Google — exibido na UI para que o usuário saiba com qual e-mail compartilhar a planilha
# Deve ser o mesmo valor de GOOGLE_CLIENT_EMAIL configurado nos secrets do Supabase
VITE_GOOGLE_SERVICE_ACCOUNT_EMAIL=

VITE_STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_BASIC_PRICE_ID=
VITE_STRIPE_PRO_PRICE_ID=
VITE_STRIPE_PREMIUM_PRICE_ID=

# ─── Backend / Supabase Edge Functions ───────────────────────────────────────
# Configure via: npx supabase secrets set KEY=value --project-ref <id>
# Ou via painel Supabase → Edge Functions → Secrets
#
# ── Stripe ──
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_BASIC_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_PREMIUM_PRICE_ID=price_...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   (já injetado automaticamente em Edge Functions)
# SITE_URL=https://seu-dominio.com   (return_url no portal Stripe)
#
# ── Z-API (instância global da plataforma — NUNCA expor no frontend) ──
# ZAPI_INSTANCE_ID=<id-da-instancia>
# ZAPI_TOKEN=<token-da-instancia>
# ZAPI_CLIENT_TOKEN=<client-token>
#
# Como obter as credenciais Z-API:
#   1. Acesse https://app.z-api.io
#   2. Crie ou selecione a instância global
#   3. Copie Instance ID, Token e Client-Token
#   4. Configure: npx supabase secrets set ZAPI_INSTANCE_ID=... ZAPI_TOKEN=... ZAPI_CLIENT_TOKEN=... --project-ref <ref>
#
# ── Google Sheets (Service Account — NUNCA expor no frontend) ──
# GOOGLE_CLIENT_EMAIL=nc-finance@projeto.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvA...\n-----END PRIVATE KEY-----\n"
#
# Como configurar a Service Account:
#   1. Google Cloud Console → IAM & Admin → Service Accounts → Criar conta
#   2. Criar chave JSON → copiar client_email e private_key
#   3. Compartilhar a planilha do usuário com o GOOGLE_CLIENT_EMAIL (visualizador)
#   4. Configure: npx supabase secrets set GOOGLE_CLIENT_EMAIL=... GOOGLE_PRIVATE_KEY=... --project-ref <ref>
#   Atenção: o GOOGLE_PRIVATE_KEY deve ter \n substituindo as quebras de linha reais ao usar CLI
#
# ── Google Drive (mesma Service Account — NUNCA expor no frontend) ──
# GOOGLE_DRIVE_FOLDER_ID=<id-da-pasta-central-de-boletos>
#
# Como configurar:
#   1. No Google Drive, crie (ou selecione) a pasta central de boletos/PDFs da plataforma
#   2. Compartilhe essa pasta com o GOOGLE_CLIENT_EMAIL (permissão de visualizador)
#   3. Copie o ID da pasta: na URL https://drive.google.com/drive/folders/FOLDER_ID
#   4. Configure: npx supabase secrets set GOOGLE_DRIVE_FOLDER_ID=<FOLDER_ID> --project-ref <ref>
#   Nota: Apenas planos Pro e Premium têm acesso à integração com o Drive
#
# ── Automação / Scheduler (NUNCA expor no frontend) ──
# AUTOMATION_CRON_SECRET=<segredo-aleatorio-forte>
#
# Como configurar:
#   1. Gere um segredo forte (ex: openssl rand -hex 32)
#   2. Configure: npx supabase secrets set AUTOMATION_CRON_SECRET=<segredo> --project-ref <ref>
#   3. Use o mesmo valor nos comandos cron.schedule() documentados na migration 20260521020000_automation.sql
#   Nota: Apenas planos Pro e Premium têm acesso à automação de cobranças
